{
    "target_player": {
        "class": "president.players.PlayerSplitter.PlayerSplitter",
        "name":  "splitter"
    },
    "data": {
        "train_hands": 100000,
        "val_hands":   12000,
        "test_hands":  12000,
        "seed":        7
    },
    "model": {
        "class": "president.models.single_meld_mlp.SingleMeldMLP",
        "architecture": {
            "hidden_sizes": [256, 256],
            "activation":   "relu",
            "dropout":      0.0
        }
    },
    "training": {
        "batch_size": 256,
        "lr":         1e-3,
        "max_epochs": 50,
        "patience":   5
    }
}
